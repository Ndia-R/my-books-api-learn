{
  "name": "my-books-api-learn",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "my-books-api-learn",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
          "vscjava.vscode-java-pack",
          "mhutchie.git-graph",
          "streetsidesoftware.code-spell-checker",
          "shengchen.vscode-checkstyle",
          "cweijan.vscode-database-client2",
          "bierner.markdown-mermaid",
          "anthropic.claude-code",
          "Google.gemini-cli-vscode-ide-companion"
      ]
    }
  },
  "postCreateCommand": "./gradlew --version && sudo chown -R vscode:vscode /home/vscode/.claude && sudo chown -R vscode:vscode /home/vscode/.gemini && sudo chmod 666 /var/run/docker.sock"
}