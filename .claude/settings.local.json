{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./gradlew:*)",
      "Bash(tree -L 3 -I 'target|build|node_modules|.git' /workspace)",
      "Bash(docker-compose ps)",
      "Bash(find /workspace/src/main/java -name \"*.java\" -type f -exec grep -l \"Security\\|@PreAuthorize\\|@Secured\\|Authentication\" {})",
      "Bash(cat /workspace/.env)",
      "Bash(docker network ls)",
      "Bash(docker network inspect vsv-emerald-network)",
      "Bash(curl -s http://host.docker.internal:8444/realms/sample-realm/protocol/openid-connect/certs)",
      "Bash(curl -s http://localhost:8080/actuator/env)",
      "Bash(echo \"JWT_ISSUER_URI: $JWT_ISSUER_URI\")",
      "Bash(echo \"JWT_JWK_SET_URI: $JWT_JWK_SET_URI\")",
      "Bash(awk '{print $2}')",
      "Bash(xargs -r kill)",
      "Bash(set -a)",
      "Bash(source .env)",
      "Bash(set +a)",
      "Bash(export)",
      "Bash(docker exec -it my-books-api-db-1 mysql -uroot -ppassword -D my-books-db -e \"SELECT id, email, name FROM users WHERE email = ''julia@gmail.com'' AND is_deleted = false;\")",
      "Bash(grep:*)",
      "Bash(pkill:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(xargs -I {} sh -c 'echo \"\"\"\"=== {} ===\"\"\"\" && head -20 {}')",
      "Bash(cat:*)",
      "Bash(rm:*)",
      "Bash(docker volume:*)",
      "Bash(docker compose:*)",
      "Bash(ls:*)",
      "mcp__serena__list_dir",
      "mcp__serena__read_file",
      "mcp__serena__activate_project",
      "mcp__serena__read_memory",
      "mcp__serena__find_file",
      "Bash(npm i:*)",
      "Bash(sudo npm i:*)",
      "Bash(claude-code --version)",
      "Bash(npm bin:*)",
      "Bash(npm prefix:*)",
      "Bash(node:*)",
      "Bash(claude:*)",
      "mcp__serena__list_memories",
      "Bash(wc:*)",
      "mcp__serena__find_symbol",
      "Bash(mysql:*)",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__search_for_pattern",
      "mcp__serena__find_referencing_symbols",
      "mcp__serena__think_about_collected_information",
      "mcp__serena__think_about_task_adherence",
      "mcp__serena__replace_content",
      "mcp__serena__think_about_whether_you_are_done",
      "mcp__serena__insert_after_symbol",
      "mcp__serena__create_text_file",
      "mcp__serena__replace_symbol_body",
      "mcp__serena__initial_instructions",
      "mcp__context7__query-docs"
    ],
    "deny": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "serena",
    "context7"
  ]
}
